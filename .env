# Environment Variables
# AmkyawDev AI Power Platform

# Server Configuration
PORT=3000
NODE_ENV=development

# OpenAI API (Add your key here)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (Add your key here)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Firebase Configuration (Already set in config/firebase.js)
# These are loaded from firebase.js configuration

# JWT Secret (Change in production)
JWT_SECRET=amkyawdev_jwt_secret_change_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL=3600
